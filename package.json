{
  "name": "e-lesen-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src && htmlhint 'pages/**/*.html'",
    "lint:js": "eslint src",
    "lint:html": "htmlhint 'pages/**/*.html'",
    "format": "prettier --write 'src/**/*.{ts,js}' 'pages/**/*.html'",
    "format:check": "prettier --check 'src/**/*.{ts,js}' 'pages/**/*.html'",
    "deploy": "npm run build && gh-pages -d dist"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "gh-pages": "^6.0.0",
    "glob": "^11.0.0",
    "htmlhint": "^1.1.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.0.0"
  },
  "dependencies": {
    "lucide": "^0.474.0"
  }
}
